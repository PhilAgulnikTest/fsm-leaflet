# Server
PORT=4000
NODE_ENV=development

# SQLite database file (relative to server/)
DATABASE_PATH=./data/fsm.db

# Public base URL — baked into QR codes at render time.
# In production this becomes whatever canonical landing URL is chosen
# (open question #5 in the brief; default for now is the dev server).
PUBLIC_BASE_URL=http://localhost:4000

# Platform admin allowlist for Pass B. Comma-separated emails.
PLATFORM_ADMIN_EMAILS=phil@entitledto.co.uk

# Anthropic API key (Pass B — AI re-write). Server-side only, never expose to client.
ANTHROPIC_API_KEY=

# Email provider (Pass B). One of: postmark, ses, none.
EMAIL_PROVIDER=none
POSTMARK_API_TOKEN=
EMAIL_FROM=fsm-leaflet@entitledto.co.uk

# Sentry DSN (optional)
SENTRY_DSN=
